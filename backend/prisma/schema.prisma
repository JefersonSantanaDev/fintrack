generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid()) @db.Uuid
  name          String
  email         String         @unique
  passwordHash  String         @map("password_hash")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  ownedFamily   Family?        @relation("FamilyOwner")
  familyMembers FamilyMember[]
  familyInvitationsSent FamilyInvitation[] @relation("FamilyInvitationInviter")
  refreshTokens RefreshToken[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  jti       String   @unique
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime @default(now()) @map("created_at")
  userId    String   @db.Uuid @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model SignupVerification {
  id                String    @id @default(uuid()) @db.Uuid
  email             String    @unique
  name              String
  passwordHash      String    @map("password_hash")
  codeHash          String    @map("code_hash")
  expiresAt         DateTime  @map("expires_at")
  resendAvailableAt DateTime  @map("resend_available_at")
  attemptCount      Int       @default(0) @map("attempt_count")
  lockedUntil       DateTime? @map("locked_until")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([expiresAt])
  @@map("signup_verifications")
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")
  userId    String   @db.Uuid @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model LoginAttempt {
  email           String    @id
  failedCount     Int       @default(0) @map("failed_count")
  windowStartedAt DateTime  @map("window_started_at")
  lockedUntil     DateTime? @map("locked_until")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([lockedUntil])
  @@map("login_attempts")
}

enum FamilyMemberRole {
  OWNER
  ADMIN
  VIEWER
}

enum FamilyInvitationStatus {
  PENDING
  ACCEPTED
  CANCELED
}

model Family {
  id          String         @id @default(uuid()) @db.Uuid
  name        String
  ownerUserId String         @unique @db.Uuid @map("owner_user_id")
  owner       User           @relation("FamilyOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  members     FamilyMember[]
  invitations FamilyInvitation[]
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  @@map("families")
}

model FamilyMember {
  id                   String           @id @default(uuid()) @db.Uuid
  familyId             String           @db.Uuid @map("family_id")
  userId               String           @db.Uuid @map("user_id")
  role                 FamilyMemberRole @default(OWNER)
  onboardingDismissedAt DateTime?       @map("onboarding_dismissed_at")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")
  family               Family           @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([familyId, userId])
  @@index([familyId])
  @@index([userId])
  @@map("family_members")
}

model FamilyInvitation {
  id            String                 @id @default(uuid()) @db.Uuid
  familyId      String                 @db.Uuid @map("family_id")
  inviterUserId String                 @db.Uuid @map("inviter_user_id")
  inviteeName   String                 @map("invitee_name")
  inviteeEmail  String                 @map("invitee_email")
  status        FamilyInvitationStatus @default(PENDING)
  sentAt        DateTime               @default(now()) @map("sent_at")
  respondedAt   DateTime?              @map("responded_at")
  createdAt     DateTime               @default(now()) @map("created_at")
  updatedAt     DateTime               @updatedAt @map("updated_at")
  family        Family                 @relation(fields: [familyId], references: [id], onDelete: Cascade)
  inviter       User                   @relation("FamilyInvitationInviter", fields: [inviterUserId], references: [id], onDelete: Cascade)

  @@unique([familyId, inviteeEmail])
  @@index([familyId, status])
  @@index([inviterUserId])
  @@map("family_invitations")
}
